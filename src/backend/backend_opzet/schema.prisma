model Assignment {
  id                   Int                 @id @default(autoincrement())
  name                 String              @db.VarChar
  deadline             DateTime?           @db.Timestamp(6)
  created_at           DateTime            @db.Timestamp(6)
  learning_path        String              @db.Uuid
  class                Int
  classes              Class               @relation(fields: [class], references: [id], onDelete: NoAction, onUpdate: NoAction)
  learning_paths       LearningPath        @relation(fields: [learning_path], references: [uuid], onDelete: NoAction, onUpdate: NoAction)
  conversation         Conversation[]
  groups               Group[]
  submissions          Submission[]
  teachers_assignments TeacherAssignment[]
}

model Class {klassen
  id               Int            @id @default(autoincrement())
  name             String?        @db.VarChar
  assignments      Assignment[]
  classes_students ClassStudent[]
  classes_teachers ClassTeacher[]
  groups           Group[]
}

model ClassStudent {
  classes_id  Int
  students_id Int
  classes     Class   @relation(fields: [classes_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students    Student @relation(fields: [students_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([classes_id, students_id])
}


model ClassTeacher {
  classes_id  Int
  teachers_id Int
  classes     Class   @relation(fields: [classes_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers    Teacher @relation(fields: [teachers_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([classes_id, teachers_id])
}

enum ContentType {
  text_plain        @map("text/plain")
  text_markdown     @map("text/markdown")
  image_image_block @map("image/image-block")
  image_image       @map("image/image")
  audio_mpeg        @map("audio/mpeg")
  application_pdf   @map("application/pdf")
  extern
  blocky
}

model Conversation {
  id                                         Int            @id @default(autoincrement())
  title                                      String?        @db.VarChar
  learning_object                            String         @db.Uuid
  teachers                                   Int
  group                                      Int
  assignment                                 Int
  assignments                                Assignment     @relation(fields: [assignment], references: [id], onDelete: NoAction, onUpdate: NoAction)
  groups                                     Group          @relation(fields: [group], references: [id], onDelete: NoAction, onUpdate: NoAction)
  learning_objects                           LearningObject @relation(fields: [learning_object], references: [uuid], onDelete: NoAction, onUpdate: NoAction)
  teachers_conversation_teachersToteachers   Teacher        @relation("conversation_To_teacher", fields: [teachers], references: [id], onDelete: NoAction, onUpdate: NoAction)
  message_message_conversationToconversation Message[]      @relation("message_To_conversation")
}

model Group {
  id              Int            @id @default(autoincrement())
  name            String?        @db.VarChar
  class           Int
  assignment      Int
  conversation    Conversation[]
  assignments     Assignment     @relation(fields: [assignment], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classes         Class          @relation(fields: [class], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students_groups StudentGroup[]
  submissions     Submission[]
}

model LearningObject {
  id                              String                       @id @map("_id") @db.VarChar
  hruid                           String                       @db.VarChar
  uuid                            String                       @unique @db.Uuid
  language                        String                       @db.VarChar
  version                         String                       @db.VarChar
  html_content                    String                       @db.VarChar
  conversation                    Conversation[]
  learning_objects_metadata       LearningObjectMetadata?
  learning_path_nodes             LearningPathNode[]
  learning_paths_learning_objects LearningPathLearningObject[]
  students_learning_objects       StudentLearningObject[]
}


model LearningObjectMetadata {
  id                String         @id @map("_id") @db.VarChar
  uuid              String         @unique @db.Uuid
  version           Int
  language          String         @db.VarChar
  title             String?        @db.VarChar
  description       String?        @db.VarChar
  content_type      ContentType?
  keywords          String[]       @db.VarChar
  target_ages       Int[]
  teacher_exclusive Boolean
  skos_concepts     String[]       @db.VarChar
  educatioanl_goals Json?          @db.Json
  copyright         String?        @db.VarChar
  license           String?        @db.VarChar
  difficulty        Int
  estimated_time    Int
  return_value      Json?          @db.Json
  available         Boolean
  content_location  String         @db.VarChar
  learning_objects  LearningObject @relation(fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model LearningPath {
  hruid                           String                       @db.VarChar
  uuid                            String                       @id @db.Uuid
  language                        String                       @db.VarChar
  title                           String?                      @db.VarChar
  description                     String?                      @db.VarChar
  image                           String?                      @db.VarChar
  assignments                     Assignment[]
  learning_path_nodes             LearningPathNode[]
  learning_paths_learning_objects LearningPathLearningObject[]
}

model LearningPathLearningObject {
  learning_paths_uuid   String         @db.Uuid
  learning_objects_uuid String         @db.Uuid
  learning_objects      LearningObject @relation(fields: [learning_objects_uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction)
  learning_paths        LearningPath   @relation(fields: [learning_paths_uuid], references: [uuid], onDelete: NoAction, onUpdate: NoAction)

  @@id([learning_paths_uuid, learning_objects_uuid])
}

model LearningPathNode {
  id                                                Int            @id @default(autoincrement())
  learning_object_id                                String         @db.VarChar
  start_node                                        Boolean?
  learning_path                                     String         @db.Uuid
  learning_objects                                  LearningObject @relation(fields: [learning_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  learning_paths                                    LearningPath   @relation(fields: [learning_path], references: [uuid], onDelete: NoAction, onUpdate: NoAction)
  transition                                        Transition?    @relation("transition_id_To_learning_path_node")
  transitions_transitions_nextTolearning_path_nodes Transition[]   @relation("transition_next_To_learning_path_nodes")
}

model Message {
  id                                              Int                       @id @default(autoincrement())
  content                                         String?                   @db.VarChar
  offset                                          Unsupported("int8range")?
  is_student                                      Boolean
  student                                         Int?
  teacher                                         Int?
  index                                           Int
  conversation                                    Int
  conversation_message_conversationToconversation Conversation              @relation("message_To_conversation", fields: [conversation], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students                                        Student?                  @relation(fields: [student], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers                                        Teacher?                  @relation(fields: [teacher], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Notification {
  id       Int      @id @default(autoincrement())
  title    String   @db.VarChar
  content  String   @db.VarChar
  read     Boolean
  student  Int?
  teacher  Int?
  students Student? @relation(fields: [student], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers Teacher? @relation(fields: [teacher], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Student {
  id                        Int                     @id @default(autoincrement())
  username                  String                  @db.VarChar
  email                     String                  @unique @db.VarChar
  password                  String?                 @db.VarChar
  created_at                DateTime                @db.Timestamp(6)
  classes_students          ClassStudent[]
  message                   Message[]
  notifications             Notification[]
  students_groups           StudentGroup[]
  students_learning_objects StudentLearningObject[]
}

model StudentGroup {
  students_id Int
  groups_id   Int
  groups      Group   @relation(fields: [groups_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students    Student @relation(fields: [students_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([students_id, groups_id])
}

model StudentLearningObject {
  students_id          Int
  learning_objects__id String         @db.VarChar
  learning_objects     LearningObject @relation(fields: [learning_objects__id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students             Student        @relation(fields: [students_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([students_id, learning_objects__id])
}

model Submission {
  id                 Int            @id @default(autoincrement())
  group              Int
  assignment         Int
  submission_type    SubmissionType
  submission_content Json           @db.Json
  graded_by          Int?
  assignments        Assignment     @relation(fields: [assignment], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers           Teacher?       @relation(fields: [graded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  groups             Group          @relation(fields: [group], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum SubmissionType {
  multiplechoice
  image
}

model Teacher {
  id                                           Int                 @id @default(autoincrement())
  username                                     String              @db.VarChar
  password                                     String?             @db.VarChar
  email                                        String              @unique @db.VarChar
  created_at                                   DateTime            @db.Timestamp(6)
  classes_teachers                             ClassTeacher[]
  conversation_conversation_teachersToteachers Conversation[]      @relation("conversation_To_teacher")
  notifications                                Notification[]
  submissions                                  Submission[]
  teachers_assignments                         TeacherAssignment[]
  Message                                      Message[]
}

model TeacherAssignment {
  teachers_id    Int
  assignments_id Int
  assignments    Assignment @relation(fields: [assignments_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers       Teacher    @relation(fields: [teachers_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([teachers_id, assignments_id])
}

model Transition {
  id                               Int                       @id @default(autoincrement())
  condition                        String?                   @db.VarChar
  default                          Boolean?
  instruction                      Unsupported("int8range")?
  next                             Int?
  corresponding_learning_path_node LearningPathNode          @relation("transition_id_To_learning_path_node", fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  next_learning_path_node          LearningPathNode?         @relation("transition_next_To_learning_path_nodes", fields: [next], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["prismaSchemaFolder"]
}

// voor lokaal testen: url kan `"postgresql://user:mysecretpassword@localhost:5432/mydatabase"` gemaakt  worden om lokaal te testen (als het via docker compose niet lukt) met een eigen database zoals bv.:
// docker run --name some-postgres     -e POSTGRES_USER=user     -e POSTGRES_PASSWORD=mysecretpassword     -e POSTGRES_DB=mydatabase     -p 5432:5432     -d postgres
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
